digraph DFA {
  rankdir=LR;
  n0 [shape=circle, label="n0"];
  n1 [shape=circle, label="n1"];
  n2 [shape=circle, label="n2"];
  n3 [shape=circle, label="n3"];
  n4 [shape=circle, label="n4"];
  n5 [shape=doublecircle, label="n5"];
  n0 -> n2 [label="a"];
  n1 -> n4 [label="ε"];
  n1 -> n0 [label="ε"];
  n2 -> n4 [label="ε"];
  n2 -> n0 [label="ε"];
  n3 -> n5 [label="ε"];
  n3 -> n1 [label="ε"];
  n4 -> n5 [label="ε"];
  n4 -> n1 [label="ε"];
}
